{
  "entities": {
    "UserMetadata": {
      "title": "User Metadata",
      "description": "Lightweight sync data for user preferences and state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "UI Theme preference" },
        "lastModified": { "type": "string", "format": "date-time", "description": "Last time metadata was changed" },
        "deviceInfo": { "type": "string", "description": "Brief description of the current device" }
      },
      "required": ["uid", "lastModified"]
    },
    "FileMetadata": {
      "title": "File Metadata",
      "description": "Metadata about local and cloud CAD files.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string", "description": "Name of the file" },
        "fileSize": { "type": "number", "description": "Size in bytes (approx)" },
        "lastModified": { "type": "string", "format": "date-time", "description": "Last modified date" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Optional user tags" },
        "isSynced": { "type": "boolean", "description": "Whether the file is stored in the cloud" }
      },
      "required": ["fileName", "lastModified"]
    },
    "DrawingContent": {
      "title": "Drawing Content",
      "description": "The actually geometric data of a drawing.",
      "type": "object",
      "properties": {
        "layers": { "type": "object" },
        "blocks": { "type": "object" },
        "settings": { "type": "object" },
        "layouts": { "type": "array" }
      },
      "required": ["layers", "settings"]
    }
  },
  "firestore": {
    "/users/{userId}/metadata": {
      "schema": "UserMetadata",
      "description": "Stores user-specific app settings and metadata."
    },
    "/users/{userId}/files/{fileId}": {
      "schema": "FileMetadata",
      "description": "Metadata for drawings."
    },
    "/users/{userId}/drawings/{fileId}": {
      "schema": "DrawingContent",
      "description": "Raw drawing content for cloud sync."
    }
  }
}
