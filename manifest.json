{
  "name": "VoxCADD Professional",
  "short_name": "VoxCADD",
  "description": "Professional Architectural CAD Engine with AI Intelligence. Full DXF/DWG Interoperability.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/favicon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "name": "VoxCADD Drawing",
      "icons": [
        {
          "src": "/favicon.svg",
          "sizes": "192x192",
          "type": "image/svg+xml"
        }
      ],
      "accept": {
        "application/x-vox": [".vox"],
        "application/vnd.voxcadd.project": [".vox"],
        "application/dxf": [".dxf"],
        "application/dwg": [".dwg"],
        "application/acad": [".dwg", ".dxf"],
        "application/x-autocad": [".dwg", ".dxf"],
        "image/vnd.dwg": [".dwg"],
        "image/vnd.dxf": [".dxf"],
        "text/plain": [".vox", ".dxf"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "shortcuts": [
    {
      "name": "New Project",
      "url": "/?action=new",
      "icons": [{ "src": "/favicon.svg", "sizes": "192x192" }]
    }
  ]
}
