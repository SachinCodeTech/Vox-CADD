{
  "name": "VoxCADD Pro",
  "short_name": "VoxCADD",
  "description": "Professional Mobile CAD Engine",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/favicon.svg",
      "sizes": "192x192",
      "type": "image/svg+xml"
    },
    {
      "src": "/favicon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/vnd.voxcadd.project": [".vox"],
        "application/dxf": [".dxf"],
        "application/acad": [".dwg"]
      }
    }
  ]
}
